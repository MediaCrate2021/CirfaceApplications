# Asana OAuth — register at https://app.asana.com/console (Cirface app identity)
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_REDIRECT_URI=http://localhost:3000/auth/callback
# For production, set to: https://your-app.railway.app/auth/callback

# Session
SESSION_SECRET=replace_with_random_32_char_string

# Server
PORT=3000
NODE_ENV=development
APP_ENV=development
# APP_ENV values: development | staging | production
# Railway sets NODE_ENV=production on all deployments — use APP_ENV to distinguish staging vs production

# Logging
LOG_LEVEL=info
# Use LOG_LEVEL=debug on staging for verbose request logging

# Production only
# ALLOWED_ORIGIN=https://your-app.railway.app
